{
  "expo": {
    "name": "Hidayet",
    "slug": "hidayet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hidayet",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c1b2a"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#0c1b2a"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0c1b2a"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
